# Backend (copy to backend/.env)
SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=sqlite:///instance/automator.db
GOOGLE_CLIENT_SECRETS_FILE=/absolute/path/to/google-oauth-client.json
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
UPLOAD_FOLDER=backend/uploads
GENERATED_FOLDER=backend/generated
MAX_CONTENT_LENGTH=2147483648
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
FLASK_ENV=development
PORT=5000
WORKER_POLL_SECONDS=5
JOB_MAX_RETRIES=3
LOG_LEVEL=INFO

# Frontend (copy VITE_API_URL to frontend/.env)
VITE_API_URL=http://localhost:5000/api
