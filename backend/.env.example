SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=sqlite:///instance/automator.db
GOOGLE_CLIENT_SECRETS_FILE=/absolute/path/to/google-oauth-client.json
TOKEN_ENCRYPTION_KEY=replace-with-a-valid-fernet-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
UPLOAD_FOLDER=uploads
GENERATED_FOLDER=generated
MAX_CONTENT_LENGTH=2147483648
FRONTEND_URL=http://localhost:8080
# Comma-separated exact origins; no paths or trailing slashes. Never use * in production.
# Include every Vercel preview/production origin that should access the API.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
FLASK_ENV=development
PORT=5000
WORKER_POLL_SECONDS=5
JOB_MAX_RETRIES=3
